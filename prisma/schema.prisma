generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id          String   @id @default(cuid())
  date        DateTime
  type        String
  category    String
  description String
  amount      Float
  createdAt   DateTime @default(now())
}

model Subscription {
  id         String    @id @default(cuid())
  name       String
  amount     Float
  dayOfMonth Int
  category   String    @default("מנוי")
  isActive   Boolean   @default(true)
  startMonth DateTime?
  endMonth   DateTime?
  createdAt  DateTime  @default(now())
}

model Shift {
  id           String   @id @default(cuid())
  date         DateTime
  startTime    String
  endTime      String
  hours        Float
  regularHours Float
  shabbatHours Float
  createdAt    DateTime @default(now())
}

model SalarySettings {
  id            String @id @default(cuid())
  month         Int
  year          Int
  referralCount Int    @default(0)

  @@unique([month, year])
}
